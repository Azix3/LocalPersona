{
  "name": "localpersona",
  "version": "0.1.23",
  "private": true,
  "description": "A local persona chat frontend for Ollama.",
  "author": {
    "name": "Azi"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Azix3/LocalPersona.git"
  },
  "homepage": "https://github.com/Azix3/LocalPersona",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "clean:release": "node -e \"require('fs').rmSync('release',{recursive:true,force:true})\"",
    "dist": "npm run clean:release && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis portable",
    "fix:deb": "node scripts/fix-deb-line-endings.cjs",
    "dist:linux": "npm run clean:release && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --linux deb tar.gz && npm run fix:deb",
    "dist:all": "npm run clean:release && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis portable --linux deb tar.gz && npm run fix:deb",
    "publish:github": "npm run dist:all && node scripts/publish-github-release.cjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "electron-updater": "^6.8.3",
    "kokoro-js": "^1.2.1",
    "vosk-browser": "^0.0.8"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "local.localpersona",
    "productName": "LocalPersona",
    "copyright": "Copyright © 2026 Azi",
    "afterPack": "scripts/patch-linux-launcher.cjs",
    "afterAllArtifactBuild": "scripts/fix-deb-line-endings.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "deb",
        "tar.gz"
      ],
      "maintainer": "Azi <Azix3@users.noreply.github.com>",
      "category": "Utility",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "afterInstall": "build/linux/after-install.tpl",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0",
        "curl"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Azix3",
        "repo": "LocalPersona",
        "releaseType": "release"
      }
    ]
  }
}
